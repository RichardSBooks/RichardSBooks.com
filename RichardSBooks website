<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Richard S. Books — Word Searches, Notebooks & More</title>
<meta name="description" content="Fun activity books, word searches, notebooks, and humor books by Richard S. Books. Available on Amazon.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #1a1a18;
    --ink-soft: #4a4a45;
    --ink-muted: #8a8a82;
    --paper: #fafaf7;
    --paper-warm: #f3f1ea;
    --paper-card: #ffffff;
    --accent: #b85c2a;
    --accent-light: #f5ede6;
    --accent-hover: #9e4e24;
    --border: rgba(26,26,24,0.10);
    --border-strong: rgba(26,26,24,0.20);
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'DM Sans', system-ui, sans-serif;
    --shadow-sm: 0 1px 4px rgba(0,0,0,0.06);
    --shadow-card: 0 4px 24px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
    --shadow-modal: 0 20px 60px rgba(0,0,0,0.15);
    --radius: 12px;
    --radius-sm: 6px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--paper);
    color: var(--ink);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250,250,247,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* HERO */
  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    display: block;
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
 .hero h1 {
   font-family: var(--font-display);
   font-size: clamp(2.8rem, 5vw, 4.5rem);
   font-weight: 600;
   line-height: 1.15;
   letter-spacing: -0.02em;
   color: var(--ink);
   margin-bottom: 1.2rem;
   max-width: 1100px; 
  }
  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }
  .hero-desc {
   font-size: 1rem;
   color: var(--ink-soft);
   line-height: 1.75;
   max-width: 1100px; 
   margin-bottom: 2rem;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: white;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.2s, transform 0.15s;
  }
  .hero-cta:hover { background: var(--accent-hover); transform: translateY(-1px); }
  .hero-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .hero-book-thumb {
    background: var(--paper-warm);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    aspect-ratio: 2/3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.2s;
  }
  .hero-book-thumb:hover { transform: translateY(-3px); }
  .hero-book-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
  }
  .hero-book-thumb.tall { grid-row: span 2; }
  .hero-book-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    text-align: center;
  }
  .hero-book-placeholder .icon { font-size: 2rem; }
  .hero-book-placeholder .label {
    font-size: 0.7rem;
    color: var(--ink-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* STATS BAR */
  .stats-bar {
    background: var(--paper-warm);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.2rem 2rem;
  }
  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 4rem;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--ink);
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  /* CATEGORIES / SECTIONS */
  .section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem;
	scroll-margin-top: 70px;
  }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .section-count {
    font-size: 0.8rem;
    color: var(--ink-muted);
    font-weight: 500;
  }

  /* BOOK GRID */
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  /* BOOK CARD */
  .book-card {
    cursor: pointer;
    background: var(--paper-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    box-shadow: var(--shadow-sm);
  }
  .book-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }
  .book-cover {
    width: 100%;
    aspect-ratio: 2/3;
    background: var(--paper-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }
  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .book-cover-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem;
    text-align: center;
    width: 100%;
    height: 100%;
  }
  .book-cover-placeholder .emoji { font-size: 2.5rem; }
  .book-cover-placeholder .title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }
  .book-cover-placeholder .subtitle {
    font-size: 0.65rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .book-info {
    padding: 0.85rem 0.9rem;
  }
  .book-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.35;
    margin-bottom: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .book-price {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }
  .book-pages {
    font-size: 0.72rem;
    color: var(--ink-muted);
    margin-top: 0.15rem;
  }

  /* MODAL OVERLAY */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,10,8,0.55);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    backdrop-filter: blur(4px);
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--paper-card);
    border-radius: 18px;
    box-shadow: var(--shadow-modal);
    width: 100%;
    max-width: 780px;
    max-height: 90vh;
    overflow-y: auto;
    display: grid;
    grid-template-columns: 240px 1fr;
    animation: modalIn 0.25s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.94) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-cover-col {
    background: var(--paper-warm);
    border-radius: 18px 0 0 18px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    border-right: 1px solid var(--border);
  }
  .modal-cover {
    width: 100%;
    aspect-ratio: 2/3;
    border-radius: 8px;
    background: white;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .modal-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .modal-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem;
    text-align: center;
    background: linear-gradient(145deg, #f8f6ee, #ede9dc);
  }
  .modal-cover-placeholder .emoji { font-size: 3rem; }
  .modal-cover-placeholder .title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink);
  }
  .modal-price-badge {
    background: var(--accent);
    color: white;
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    letter-spacing: -0.01em;
  }
  .modal-amazon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    background: #FF9900;
    color: #111;
    text-decoration: none;
    padding: 0.65rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.2s, transform 0.15s;
  }
  .modal-amazon-btn:hover { background: #e68a00; transform: translateY(-1px); }
  .modal-amazon-btn svg { flex-shrink: 0; }

  .modal-content-col {
    padding: 2rem 2rem 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--paper-card);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: var(--ink-soft);
    transition: background 0.15s;
    z-index: 10;
  }
  .modal-close:hover { background: var(--paper-warm); }
  .modal-wrap { position: relative; }

  .modal-category-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.25rem 0.65rem;
    border-radius: 50px;
  }
  .modal-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .modal-desc {
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.75;
  }

  .modal-meta {
    display: flex;
    gap: 1.5rem;
    padding: 0.85rem 1rem;
    background: var(--paper-warm);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
  .meta-item { display: flex; flex-direction: column; gap: 0.1rem; }
  .meta-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-muted); font-weight: 500; }
  .meta-value { font-size: 0.88rem; font-weight: 500; color: var(--ink); }

  .modal-previews-title {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.5rem;
  }
  .modal-previews {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .preview-img {
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--paper-warm);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .preview-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .preview-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem;
    text-align: center;
  }
  .preview-placeholder span {
    font-size: 0.65rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ABOUT SECTION */
  .about-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 4rem 2rem;
  }
  .about-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .about-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .about-text {
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }
  .about-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 7px;
  }
  .feature-text {
    font-size: 0.82rem;
    color: var(--ink-soft);
    line-height: 1.45;
  }
  .about-quote {
    background: var(--paper-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.5rem;
  }
  .quote-text {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .quote-author {
    font-size: 0.8rem;
    color: var(--ink-muted);
    font-weight: 500;
  }

  /* FOOTER */
  footer {
    background: var(--ink);
    color: rgba(255,255,255,0.6);
    padding: 2.5rem 2rem;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    font-weight: 600;
  }
  .footer-logo span { color: #e8945a; }
  .footer-text { font-size: 0.8rem; }
  .footer-link {
    color: #e8945a;
    text-decoration: none;
  }
  .footer-link:hover { text-decoration: underline; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; gap: 2.5rem; padding: 3rem 1.25rem 2.5rem; }
    .hero-visual { display: none; }
    .stats-inner { gap: 2rem; }
    .modal { grid-template-columns: 1fr; max-width: 420px; }
    .modal-cover-col { border-radius: 18px 18px 0 0; border-right: none; border-bottom: 1px solid var(--border); flex-direction: row; align-items: flex-start; gap: 1.25rem; }
    .modal-cover { width: 120px; flex-shrink: 0; }
    .modal-price-badge { font-size: 0.9rem; }
    .about-inner { grid-template-columns: 1fr; gap: 2rem; }
    .nav-links { display: none; }
  }
</style>
</head>
