function openModal(id) {
  const b = books[id];
  if (!b) return;

  document.getElementById('modalTitle').textContent = b.title;
  document.getElementById('modalCategory').textContent = b.category;
  document.getElementById('modalPrice').textContent = b.price;
  document.getElementById('modalDesc').textContent = b.desc;
  document.getElementById('modalAmazonBtn').href = b.amazonUrl;

  document.getElementById('modalCover').innerHTML = b.coverImg
    ? `<img src="${b.coverImg}" alt="${b.title}" style="width:100%;height:100%;object-fit:cover;">`
    : `<div class="modal-cover-placeholder"><span class="emoji">${b.coverEmoji}</span><span class="title">${b.title}</span></div>`;

  document.getElementById('modalMeta').innerHTML = `
    <div class="meta-item"><span class="meta-label">Pages</span><span class="meta-value">${b.pages}</span></div>
    <div class="meta-item"><span class="meta-label">Size</span><span class="meta-value">${b.size}</span></div>
    <div class="meta-item"><span class="meta-label">Language</span><span class="meta-value">${b.language}</span></div>
    <div class="meta-item"><span class="meta-label">Format</span><span class="meta-value">Paperback</span></div>`;

  document.getElementById('modalPreviews').innerHTML = `
    <div class="preview-img">${b.sampleImg 
        ? `<img src="${b.sampleImg}" alt="Sample page" style="width:100%;height:100%;object-fit:cover;">` 
        : `<div class="preview-placeholder"><span>📄</span><span>${b.previewLabel1}</span></div>`}
    </div>
    <div class="preview-img">${b.backImg 
        ? `<img src="${b.backImg}" alt="Back cover" style="width:100%;height:100%;object-fit:cover;">` 
        : `<div class="preview-placeholder"><span>📄</span><span>${b.previewLabel2}</span></div>`}
    </div>`;

  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

function closeModalOutside(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
}

document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
